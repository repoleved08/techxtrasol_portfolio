# Environment variables example file
# Copy this to .env.local and fill in your actual values

# Resend API Key for email sending (get from https://resend.com/api-keys)
VITE_RESEND_API_KEY=

# Note for Vercel:
# Configure environment variables in Vercel dashboard:
# 1. Go to your Vercel project settings
# 2. Navigate to Environment Variables
# 3. Add RESEND_API_KEY with your actual Resend API key
# 4. The function will automatically have access to it via process.env.RESEND_API_KEY
